{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    /* This ignores errors in your dependencies (node_modules) */
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["custom-tab-card.ts", "vite.config.ts"],
  "exclude": ["node_modules"]
}